{
    "name": "@freehour/supabase-core",
    "private": false,
    "displayName": "Supabase-Core",
    "description": "Lightweight services for supabase to make it easier to work with databases, tables and storage buckets",
    "version": "1.1.2",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/freehour/supabase-core.git"
    },
    "scripts": {
        "lint": "eslint ./lib --ext ts",
        "build": "bun run lint && tsc && vite build",
        "postinstall": "bun ./scripts/copy-supabase-assets.js"
    },
    "files": [
        "dist",
        "supabase/migrations",
        "supabase/schemas",
        "scripts"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "dependencies": {
        "@freehour/assert": "1.0.0",
        "@freehour/mime": "^1.0.5",
        "@supabase/storage-js": "^2.99.3",
        "@supabase/supabase-js": "2.99.3",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin-js": "2.10.1",
        "@stylistic/eslint-plugin-plus": "2.10.1",
        "@stylistic/eslint-plugin-ts": "2.10.1",
        "@typescript-eslint/eslint-plugin": "8.14.0",
        "@typescript-eslint/parser": "8.14.0",
        "ajv": "^8.18.0",
        "bun-types": "^1.3.11",
        "eslint": "8.57.1",
        "eslint-import-resolver-typescript": "3.6.3",
        "eslint-plugin-import-x": "4.4.3",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "supabase": "^2.83.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vite-tsconfig-paths": "^5.1.4"
    }
}