{
  "name": "@freehour/supabase-core",
  "private": false,
  "displayName": "Supabase-Core",
  "description": "Lightweight services for supabase to make it easier to work with databases, tables and storage buckets",
  "version": "2.0.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freehour/supabase-core.git"
  },
  "scripts": {
    "lint": "eslint ./lib --ext ts",
    "build": "bun run lint && tsc && vite build",
    "postinstall": "bun ./scripts/copy-supabase-assets.js"
  },
  "files": [
    "dist",
    "supabase/migrations/0000_supabase_core.sql",
    "supabase/schemas/supabase-core",
    "scripts/copy-supabase-assets.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@freehour/assert": "^1.0.0",
    "@supabase/postgrest-js": "^2.103.0",
    "@supabase/storage-js": "^2.103.0",
    "@supabase/supabase-js": "^2.103.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@freehour/eslint-rules": "^1.0.19",
    "ajv": "^8.18.0",
    "bun-types": "^1.3.11",
    "eslint": "9.39.4",
    "supabase": "^2.88.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}